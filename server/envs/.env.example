# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8080
READ_TIMEOUT=30
WRITE_TIMEOUT=30

# =============================================================================
# Database（PostgreSQL + asyncpg）
# docker compose 利用時は compose 側の postgres サービス名をホストにする
# 例: postgresql+asyncpg://USER:PASSWORD@postgres:5432/DBNAME
# =============================================================================
DATABASE_URL=postgresql+asyncpg://smartcycle:smartcycle@localhost:5432/smartcycle

# =============================================================================
# JWT（本番では十分に長いランダム文字列に変更すること）
# =============================================================================
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-ok
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# =============================================================================
# 開発・検証用テストアカウント
# true にすると起動時に admin@mail.com / dev@mail.com / user@mail.com を冪等投入
# パスワードは docs/test-accounts.md を参照
# 本番環境では必ず false のままにすること
# =============================================================================
SEED_DEV_USERS=false

# =============================================================================
# LINE Messaging API（EV3 タッチセンサー連携時の空き状況通知）
# 未設定の場合は通知をスキップします
# https://developers.line.biz/ja/docs/messaging-api/
# =============================================================================
# 例: 170文字前後の英数字（チャネル ID の 2010057748 などではない）
# LINE_CHANNEL_ACCESS_TOKEN=
# 友だち全員へ送る（デフォルト true）。開発時のみ個別プッシュに切り替え可能
# LINE_USE_BROADCAST=true
# LINE_USE_BROADCAST=false のときのみ指定（ユーザー ID は U で始まる）
# LINE_NOTIFY_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
