# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8080
READ_TIMEOUT=30
WRITE_TIMEOUT=30

# =============================================================================
# Database（PostgreSQL + asyncpg）
# docker compose 利用時は compose 側の postgres サービス名をホストにする
# 例: postgresql+asyncpg://USER:PASSWORD@postgres:5432/DBNAME
# =============================================================================
DATABASE_URL=postgresql+asyncpg://smartcycle:smartcycle@localhost:5432/smartcycle

# =============================================================================
# JWT（本番では十分に長いランダム文字列に変更すること）
# =============================================================================
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-ok
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
