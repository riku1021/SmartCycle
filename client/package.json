{
  "name": "smart-cycle",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "lint:fix": "biome check --write .",
    "preview": "tsc -b && vite build && vite preview",
    "preview:serve": "vite preview",
    "sort-package-json": "sort-package-json --check",
    "sort-package-json:fix": "sort-package-json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-spring/web": "^10.0.0",
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-router": "^1.168.3",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "jotai": "^2.19.0",
    "jotai-tanstack-query": "^0.11.0",
    "leaflet": "^1.9.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-icons": "^5.6.0",
    "sweetalert2": "^11.26.24"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/router-devtools": "1.166.11",
    "@tanstack/router-plugin": "1.167.8",
    "@types/leaflet": "^1.9.21",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "sort-package-json": "3.6.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-svgr": "4.5.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "6"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core"
    ]
  }
}
